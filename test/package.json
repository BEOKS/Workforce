    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "multiple-cucumber-html-reporter": "^3.9.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "yaml": "^2.6.1"
  }
}
