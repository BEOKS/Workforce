# compose
COMPOSE_PROJECT_NAME=workforce-it

# ports
SUT_PORT=8080
MOCKSERVER_PORT=1080

# base urls
SUT_BASE_URL=http://localhost:8080
MOCKSERVER_BASE_URL=http://localhost:1080
TICKET_PLATFORM_BASE_URL=http://localhost:1080

# SUT endpoint paths (contract-first)
SUT_HEALTH_PATH=/healthz
SUT_CREATE_TICKET_PATH=/v1/tickets
SUT_GET_ELIGIBILITY_PATH=/v1/tickets/{ticketId}/eligibility
SUT_POST_INSPECTION_ANSWER_PATH=/v1/tickets/{ticketId}/inspection/answers
SUT_TRIGGER_EXECUTION_PATH=/v1/tickets/{ticketId}/execute
SUT_GET_STATUS_PATH=/v1/tickets/{ticketId}/status
SUT_GET_INGESTION_STATUS_PATH=/v1/ingestion/status
SUT_GET_PLATFORM_TICKET_PATH=/v1/platform/tickets/{platformTicketId}

# test behavior
REQUEST_TIMEOUT_MS=15000
